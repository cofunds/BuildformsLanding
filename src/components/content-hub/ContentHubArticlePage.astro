---
import type { HubContentItem, HubFaqEntry, HubHeadingNav, HubPostDetail } from '@/lib/contentHub';
import { hubItemHref } from '@/lib/contentHub';

type Props = {
	post: HubPostDetail;
	related: HubContentItem[];
	headings: HubHeadingNav[];
	readingTime: number;
	middleCrumb: { label: string; href: string };
	faqItems: HubFaqEntry[];
	breadcrumbLd?: string;
	articleLd?: string;
	faqLd?: string;
	howToLd?: string;
};

const {
	post,
	related,
	headings,
	readingTime,
	middleCrumb,
	faqItems,
	breadcrumbLd,
	articleLd,
	faqLd,
	howToLd,
} = Astro.props;

const bodyClass =
	'hub-article-body max-w-none text-foreground text-lg leading-relaxed [&_h1]:scroll-mt-24 [&_h2]:scroll-mt-24 [&_h3]:scroll-mt-24 [&_a]:text-primary [&_a]:underline [&_a]:underline-offset-2 [&_blockquote]:border-l-4 [&_blockquote]:border-primary [&_blockquote]:pl-4 [&_blockquote]:not-italic [&_table]:text-sm [&_p]:mb-4 [&_ul]:my-4 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:my-4 [&_ol]:list-decimal [&_ol]:pl-6 [&_img]:max-w-full [&_img]:rounded-md [&_pre]:overflow-x-auto [&_pre]:rounded-md [&_pre]:bg-muted [&_pre]:p-4 [&_code]:rounded [&_code]:bg-muted [&_code]:px-1';
---

{
	breadcrumbLd && (
		<script type="application/ld+json" is:inline set:html={breadcrumbLd} />
	)
}
{articleLd && <script type="application/ld+json" is:inline set:html={articleLd} />}
{howToLd && <script type="application/ld+json" is:inline set:html={howToLd} />}
{faqLd && <script type="application/ld+json" is:inline set:html={faqLd} />}

<article class="max-w-4xl mx-auto px-6">
	<nav class="text-sm text-muted-foreground mb-6" aria-label="Breadcrumb">
		<a href="/blogs" class="hover:underline">Resources</a>
		{' '}/{' '}
		<a href={middleCrumb.href} class="hover:underline">
			{middleCrumb.label}
		</a>
		{' '}/ <span class="text-foreground">{post.title}</span>
	</nav>

	<header class="mb-10">
		<h1 class="text-4xl font-bold mb-4 leading-tight text-foreground">
			{post.title}
		</h1>
		{
			post.excerpt && (
				<p class="text-xl text-muted-foreground mb-4">{post.excerpt}</p>
			)
		}
		<div class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground">
			{
				post.publishedAt && (
					<time datetime={post.publishedAt}>
						{new Date(post.publishedAt).toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric',
						})}
					</time>
				)
			}
			<span aria-hidden="true">·</span>
			<span>{readingTime} min read</span>
		</div>
	</header>

	<div class="flex gap-10">
		{
			headings.length > 3 && (
				<aside class="hidden lg:block w-56 shrink-0">
					<nav class="sticky top-24" aria-label="On this page">
						<h4 class="text-xs font-semibold uppercase text-muted-foreground mb-3 tracking-wider">
							On this page
						</h4>
						<ul class="space-y-2 text-sm border-l border-border pl-3">
							{headings.map((h) => (
								<li class:list={[{ 'pl-3': h.level === 3 }]}>
									<a
										href={`#${h.id}`}
										class="text-muted-foreground hover:text-foreground transition-colors"
									>
										{h.text}
									</a>
								</li>
							))}
						</ul>
					</nav>
				</aside>
			)
		}

		<div class="flex-1 min-w-0">
			<div class={bodyClass} set:html={post.body} />

			{
				faqItems.length > 0 && (
					<section class="mt-12 border-t border-border pt-8">
						<h2 class="text-2xl font-bold mb-6 text-foreground">Frequently Asked Questions</h2>
						<div class="space-y-6">
							{faqItems.map((faq) => (
								<details class="group">
									<summary class="cursor-pointer font-medium text-lg text-foreground hover:text-primary transition-colors list-none [&::-webkit-details-marker]:hidden">
										<span class="inline-block border-b border-transparent group-open:border-primary">
											{faq.question}
										</span>
									</summary>
									<p class="mt-2 text-muted-foreground pl-0">{faq.answer}</p>
								</details>
							))}
						</div>
					</section>
				)
			}

			{
				related.length > 0 && (
					<section class="mt-12 border-t border-border pt-10">
						<h3 class="text-xl font-semibold mb-6 text-foreground">Keep Reading</h3>
						<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
							{related.map((r) => (
								<a
									href={hubItemHref(r)}
									class="block border border-border rounded-lg p-4 hover:border-foreground/20 transition-colors"
								>
									<h4 class="font-medium mb-1 line-clamp-2 text-foreground">{r.title}</h4>
									{r.excerpt && (
										<p class="text-sm text-muted-foreground line-clamp-2">{r.excerpt}</p>
									)}
								</a>
							))}
						</div>
					</section>
				)
			}
		</div>
	</div>
</article>
