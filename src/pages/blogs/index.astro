---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import { PostHogRoot } from '../../components/islands/PostHogRoot';
import { fetchPublishedHubContent } from '@/lib/contentHubDb';
import {
	estimateReadingTime,
	hubItemHref,
	PUBLISHED_CONTENT_TYPES,
	type HubContentItem,
	type PublishedContentType,
} from '@/lib/contentHub';

const SITE_URL = 'https://buildforms.so';

const title = 'Hiring Resources for Startup Founders | BuildForms';
const description =
	'Actionable guides and articles about startup hiring, candidate evaluation, and building teams without the enterprise bloat. Written by founders, for founders.';

const im = import.meta.env as Record<string, string | undefined>;
const hubResult = await fetchPublishedHubContent(im.DATABASE_URL);
const published: HubContentItem[] = hubResult.ok ? hubResult.items : [];

const typeParam = Astro.url.searchParams.get('type');
const filterType: PublishedContentType | undefined =
	typeParam && (PUBLISHED_CONTENT_TYPES as readonly string[]).includes(typeParam)
		? (typeParam as PublishedContentType)
		: undefined;

const items = filterType ? published.filter((p) => p.type === filterType) : published;
const featured = items[0];
const rest = items.slice(1);

const filters: { label: string; value?: PublishedContentType }[] = [
	{ label: 'All' },
	{ label: 'Articles', value: 'blog' },
	{ label: 'Guides', value: 'guide' },
	{ label: 'Solutions', value: 'landing-page' },
];

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE_URL },
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Resources',
			item: `${SITE_URL}/blogs`,
		},
	],
};

function typeLabel(type: string): string {
	if (type === 'guide') return 'guide';
	if (type === 'landing-page') return 'solution';
	return 'article';
}

function formatDate(iso: string | null, style: 'short' | 'long' = 'short') {
	if (!iso) return '';
	const d = new Date(iso);
	if (Number.isNaN(d.getTime())) return '';
	if (style === 'long') {
		return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
	}
	return d.toLocaleDateString();
}
---

<BaseLayout {title} {description} path="/blogs">
	<script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbSchema)} />
	<PostHogRoot client:load />
	<div class="min-h-screen bg-background">
		<Navbar client:load />
		<main class="pt-24 sm:pt-28 pb-16 sm:pb-20">
			<div class="max-w-5xl mx-auto px-6 py-12">
				<div class="space-y-8 sm:space-y-10">
					<div>
						<h1 class="text-3xl font-bold text-foreground">Hiring Resources for Founders</h1>
						<p class="text-muted-foreground mt-2 max-w-2xl text-sm sm:text-base leading-relaxed">
							Practical guides on startup hiring, candidate evaluation, and building teams without the
							enterprise bloat. Written by founders who have been through it.
						</p>
					</div>

					{
						published.length === 0 ? (
							<p class="text-muted-foreground text-sm sm:text-base">
								Content coming soon. Check back later.
							</p>
						) : (
							<>
								<div
									class="flex gap-2 overflow-x-auto pb-1 -mx-1 px-1 border-b border-border"
									role="navigation"
									aria-label="Content type"
								>
									{
										filters.map((f) => {
											const isActive = (f.value ?? 'all') === (filterType ?? 'all');
											const href = f.value ? `/blogs?type=${f.value}` : '/blogs';
											return (
												<a
													href={href}
													class:list={[
														'font-mono text-[11px] sm:text-xs uppercase tracking-[0.12em] px-3.5 sm:px-4 py-1.5 rounded-sm border transition-colors whitespace-nowrap shrink-0',
														isActive
															? 'bg-foreground border-foreground text-background'
															: 'bg-background border-border text-muted-foreground hover:border-foreground/30 hover:text-foreground',
													]}
												>
													{f.label}
												</a>
											);
										})
									}
								</div>

								{items.length === 0 ? (
									<div class="py-12 sm:py-16 text-center rounded-lg border border-border bg-muted/20 mt-6 sm:mt-8">
										<p class="font-mono text-[11px] sm:text-xs uppercase tracking-[0.12em] text-muted-foreground mb-2">
											no matches
										</p>
										<p class="text-muted-foreground text-sm sm:text-base max-w-md mx-auto px-4">
											Nothing published in this category yet. Try another tab or view all resources.
										</p>
									</div>
								) : (
									<div class="space-y-8 sm:space-y-10 mt-6 sm:mt-8">
										{
											featured && (
												<a
													href={hubItemHref(featured)}
													class="block border border-border rounded-lg p-6 sm:p-8 hover:border-foreground/25 transition-colors bg-card"
												>
													<div class="flex flex-col gap-4 sm:gap-5">
														<div class="flex items-center gap-2 sm:gap-3 flex-wrap">
															<span class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.15em] px-2 py-1 rounded-sm bg-foreground text-background">
																featured
															</span>
															<span class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.15em] text-muted-foreground">
																{typeLabel(featured.type)}
															</span>
														</div>
														<h2 class="text-2xl sm:text-3xl font-bold text-foreground leading-tight">
															{featured.title}
														</h2>
														{featured.excerpt && (
															<p class="text-muted-foreground text-sm sm:text-base leading-relaxed max-w-3xl">
																{featured.excerpt}
															</p>
														)}
														<div class="flex items-center gap-2 sm:gap-2.5 font-mono text-[11px] sm:text-xs text-muted-foreground flex-wrap">
															{featured.publishedAt && (
																<span>{formatDate(featured.publishedAt, 'long')}</span>
															)}
															<span aria-hidden="true">&middot;</span>
															<span>{estimateReadingTime(featured.body)} min read</span>
														</div>
													</div>
												</a>
											)
										}

										{
											rest.length > 0 && (
												<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5">
													{rest.map((item) => (
														<a
															href={hubItemHref(item)}
															class="group block border border-border rounded-lg p-5 sm:p-6 hover:border-foreground/25 transition-colors bg-card h-full flex flex-col"
														>
															<p class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.15em] text-muted-foreground mb-2 sm:mb-3">
																{typeLabel(item.type)}
															</p>
															<h3 class="text-base sm:text-lg font-semibold leading-snug text-foreground mb-2 sm:mb-3 group-hover:text-primary transition-colors line-clamp-3">
																{item.title}
															</h3>
															{item.excerpt && (
																<p class="text-sm text-muted-foreground leading-relaxed mb-4 sm:mb-5 line-clamp-3 flex-1">
																	{item.excerpt}
																</p>
															)}
															<div class="flex items-center gap-2 font-mono text-[11px] text-muted-foreground flex-wrap mt-auto">
																{item.publishedAt && <span>{formatDate(item.publishedAt)}</span>}
																<span aria-hidden="true">&middot;</span>
																<span>{estimateReadingTime(item.body)} min</span>
															</div>
														</a>
													))}
												</div>
											)
										}
									</div>
								)}
							</>
						)
					}
				</div>
			</div>
		</main>
		<Footer />
	</div>
</BaseLayout>
