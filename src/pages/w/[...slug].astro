---
/**
 * Ensures /w/* hits the SSR pipeline so middleware can merge OG metadata and redirect to beta.
 */
export const prerender = false;

const target = new URL(Astro.url.pathname + Astro.url.search + Astro.url.hash, 'https://beta.buildforms.so');
return Astro.redirect(target.toString(), 307);
---
