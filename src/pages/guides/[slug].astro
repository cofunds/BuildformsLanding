---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar';
import Footer from '../../components/Footer';
import ContentHubArticlePage from '../../components/content-hub/ContentHubArticlePage.astro';
import { BookDemoModalIsland } from '../../components/islands/BookDemoModalIsland';
import { PostHogRoot } from '../../components/islands/PostHogRoot';
import { resolveHubArticle } from '@/lib/contentHubArticlePageData';

const slug = Astro.params.slug;
if (!slug) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const im = import.meta.env as Record<string, string | undefined>;
const data = await resolveHubArticle(slug, 'guide', im.DATABASE_URL);
if (!data) {
	return new Response(null, { status: 404, statusText: 'Not Found' });
}

const {
	post,
	related,
	headings,
	readingTime,
	middleCrumb,
	faqItems,
	breadcrumbLd,
	articleLd,
	faqLd,
	howToLd,
	canonicalPath,
} = data;
const title = `${post.title} — BuildForms`;
const description = post.excerpt ?? 'BuildForms guide.';
---

<BaseLayout {title} {description} path={canonicalPath}>
	<PostHogRoot client:load />
	<div class="min-h-screen bg-background">
		<Navbar client:load />
		<main class="pt-24 sm:pt-28 pb-16 sm:pb-20">
			<div class="max-w-5xl mx-auto px-6 py-12">
			<ContentHubArticlePage
				post={post}
				related={related}
				headings={headings}
				readingTime={readingTime}
				middleCrumb={middleCrumb}
				faqItems={faqItems}
				breadcrumbLd={breadcrumbLd}
				articleLd={articleLd}
				faqLd={faqLd}
				howToLd={howToLd}
			/>
			</div>
		</main>
		<Footer />
	</div>
	<BookDemoModalIsland client:idle />
</BaseLayout>
