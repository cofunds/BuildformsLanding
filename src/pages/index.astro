---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import { LandingMarketingIsland } from '../components/islands/LandingMarketingIsland';
import { BookDemoModalIsland } from '../components/islands/BookDemoModalIsland';
import { PostHogRoot } from '../components/islands/PostHogRoot';

const title = 'BuildForms - AI Hiring OS for Startups & Small Teams';
const description =
	'BuildForms is an AI-powered hiring OS that helps startups collect structured applications, evaluate candidates with AI, and hire faster. Set up your hiring pipeline in minutes.';
---

<BaseLayout {title} {description} includeProductSchema={true}>
	<PostHogRoot client:load />
	<LandingMarketingIsland client:visible />
	<BookDemoModalIsland client:idle />
</BaseLayout>
