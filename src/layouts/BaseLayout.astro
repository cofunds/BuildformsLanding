---
import '../styles/global.css';
import faviconIco from '../assets/favicon.ico?url';
import { ClientRouter } from 'astro:transitions';
import ContentHubAnalytics from '@/components/content-hub/ContentHubAnalytics';

type Props = {
	title: string;
	description: string;
	ogImage?: string;
	path?: string;
	noindex?: boolean;
};

const site = 'https://buildforms.so';
const {
	title,
	description,
	ogImage = 'https://beta.buildforms.so/api/og',
	path = Astro.url.pathname,
	noindex = false,
} = Astro.props;

const canonical = new URL(path, site).toString();
const jsonLd = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'BuildForms',
	applicationCategory: 'BusinessApplication',
	description:
		'AI-powered hiring OS that helps startups and small teams collect structured applications, evaluate candidates with AI, and make faster hiring decisions.',
	operatingSystem: 'Web',
	offers: {
		'@type': 'Offer',
		price: '0',
		priceCurrency: 'USD',
		description: 'Free plan available',
	},
};
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600;1,700&display=swap"
		/>
		<link rel="icon" type="image/svg+xml" href={faviconIco} />
		<link rel="icon" href={faviconIco} sizes="any" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonical} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta
			name="keywords"
			content="AI hiring tool, hiring OS for startups, applicant evaluation software, AI resume screening, structured hiring, candidate evaluation, hiring pipeline, small team hiring, AI applicant tracking, automated candidate screening"
		/>
		<meta name="author" content="BuildForms" />
		{noindex ? (
			<meta name="robots" content="noindex, follow" />
		) : (
			<meta name="robots" content="index, follow" />
		)}
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:site_name" content="BuildForms" />
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
		<script is:inline>
			(function () {
				var path = location.pathname;
				var ogBase = 'https://beta.buildforms.so/api/og';
				var formMatch = path.match(/^\/f\/([^/?#]+)/);
				var workspaceMatch = path.match(/^\/w\//);
				var ogImage = ogBase;

				function safeDecodeSegment(segment) {
					try {
						return decodeURIComponent(segment);
					} catch (e) {
						return segment;
					}
				}

				if (formMatch) {
					ogImage = ogBase + '?slug=' + encodeURIComponent(safeDecodeSegment(formMatch[1]));
				}

				if (!formMatch && !workspaceMatch) return;

				function setMeta(selector, attr, value) {
					var el = document.querySelector(selector);
					if (el) el.setAttribute(attr, value);
				}

				setMeta('meta[property="og:image"]', 'content', ogImage);
				setMeta('meta[name="twitter:image"]', 'content', ogImage);
				setMeta('meta[property="og:url"]', 'content', location.href);
				setMeta('link[rel="canonical"]', 'href', location.href);
			})();
		</script>
	</head>
	<body class="min-h-dvh bg-background text-foreground">
		<div class="hub-route-progress-bar" aria-hidden="true"></div>
		<ClientRouter />
		<ContentHubAnalytics client:load />
		<slot />
		<script is:inline>
			document.addEventListener('astro:before-preparation', function () {
				document.documentElement.classList.add('astro-route-loading');
			});
			document.addEventListener('astro:page-load', function () {
				document.documentElement.classList.remove('astro-route-loading');
			});
		</script>
	</body>
</html>
